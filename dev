#!/usr/bin/env bash
# Usage:
#   ./dev                        # interactive default shell
#   ./dev cargo build            # run a command in the default shell
#   ./dev -d                     # interactive dev shell (neovim, claude-code, …)
#   ./dev -d pre-commit run      # run a command in the dev shell

set -euo pipefail

shell="default"
if [[ "${1:-}" == "-d" || "${1:-}" == "--dev" ]]; then
  shell="dev"
  shift
fi

if [[ $# -eq 0 ]]; then
  exec nix develop ".#${shell}"
else
  exec nix develop ".#${shell}" --command "$@"
fi
